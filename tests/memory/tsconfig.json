{
  "compilerOptions": {
    "target": "es2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node", "@playwright/test"],
    "baseUrl": ".",
    "paths": {
      "simple-table-core": ["../../packages/core/src/index.ts"],
      "@simple-table/react": ["../../packages/react/src/index.ts"]
    }
  },
  "include": ["src", "harness", "playwright.config.ts", "vite.config.ts"]
}
