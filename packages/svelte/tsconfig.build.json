{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationDir": "dist/types",
    "outDir": "dist",
    "rootDir": "src",
    "target": "ES2017",
    "verbatimModuleSyntax": true
  },
  "exclude": ["node_modules", "dist", "src/**/__tests__/**"]
}
